---
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = [
  {
    title: "Morning Ritual Guide",
    description: "A printable guide to building a steady morning practice that supports calm, focus, and nervous system relief.",
    type: "PDF Guide",
    icon: "☀️",
    href: "/resources/morning-ritual-guide",
    cta: "Open Guide",
    available: true,
  },
  {
    title: "Midlife Brain Fog Checklist",
    description: "A simple checklist to help you notice focus issues, memory slips, overwhelm, and patterns worth tracking.",
    type: "Worksheet",
    icon: "🧠",
    href: null,
    cta: "Coming Soon",
    available: false,
  },
  {
    title: "Doctor Prep Questions for Perimenopause",
    description: "A clear question sheet for appointments about symptoms, cycle changes, sleep issues, mood shifts, and treatment options.",
    type: "Assessment",
    icon: "✎",
    href: null,
    cta: "Coming Soon",
    available: false,
  },
  {
    title: "Sleep Reset Audio",
    description: "A short guided audio for women who need help winding down after restless, overstimulated days.",
    type: "Audio",
    icon: "🌿",
    href: null,
    cta: "Coming Soon",
    available: false,
  },
  {
    title: "Perimenopause Symptom Snapshot",
    description: "A one-page tracker that helps you notice the symptoms affecting your energy, sleep, mood, and daily function.",
    type: "Checklist",
    icon: "❋",
    href: null,
    cta: "Coming Soon",
    available: false,
  },
  {
    title: "Journal Prompts for Midlife Overwhelm",
    description: "Reflection prompts for women who feel unlike themselves and want language for what this season is bringing up.",
    type: "Journal",
    icon: "✧",
    href: null,
    cta: "Coming Soon",
    available: false,
  }
];
---

<BaseLayout title="Resources" description="Free perimenopause resources including symptom tools, morning reset support, brain fog checklists, and appointment prep worksheets.">
  <section class="resources-hero">
    <div class="container">
      <span class="page-label">Free Tools</span>
      <h1>Resources</h1>
      <p class="lead">
        Practical tools for perimenopause, brain fog, mood shifts, sleep disruption, and daily rhythm support.
      </p>
    </div>
  </section>

  <section class="section resources-content">
    <div class="container">
      <div class="resources-grid">
        {resources.map(resource => (
          <div class={`resource-card ${resource.available ? 'resource-card-live' : ''}`}>
            <span class="resource-icon">{resource.icon}</span>
            <span class="resource-type">{resource.type}</span>
            <h3 class="resource-title">{resource.title}</h3>
            <p class="resource-description">{resource.description}</p>
            {resource.available ? (
              <a href={resource.href} class="btn resource-link">{resource.cta}</a>
            ) : (
              <button class="resource-btn">{resource.cta}</button>
            )}
          </div>
        ))}
      </div>

      <div class="focus-note">
        <h2>What these resources focus on</h2>
        <p>
          Balanced Feminine Path centers perimenopause with extra attention on brain fog, focus struggles,
          mood shifts, overwhelm, sleep trouble, and the symptom patterns that can make midlife feel confusing.
        </p>
      </div>
    </div>
  </section>

  <section class="section cta-resources">
    <div class="container">
      <div class="shop-callout">
        <span class="resource-type">New in the shop</span>
        <h2>Need deeper support than a free download?</h2>
        <p>
          Explore the digital product collection for perimenopause support, sleep help,
          brain fog tools, morning reset work, and midlife planning.
        </p>
        <a href="/shop" class="btn">Visit the Shop</a>
      </div>

      <div class="cta-card">
        <h2>Looking for Something Specific?</h2>
        <p>
          Have a topic you'd like to see covered? A resource you wish existed? 
          Let us know—we'd love to hear from you.
        </p>
        <a href="/contact" class="btn">Request a Resource</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resources-hero {
    background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    padding: 5rem var(--spacing) 3rem;
    text-align: center;
  }

  .page-label {
    display: inline-block;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .resources-hero h1 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .resources-content {
    background: var(--color-white);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .resource-card {
    background: var(--color-bg);
    padding: 2rem;
    border-radius: var(--border-radius);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .resource-card-live {
    background: linear-gradient(180deg, var(--color-bg) 0%, #fffdfb 100%);
    border: 1px solid rgba(139, 107, 93, 0.12);
  }

  .resource-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(139, 107, 93, 0.1);
  }

  .resource-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .resource-type {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-white);
    background: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .resource-title {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .resource-description {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .resource-btn {
    background: var(--color-bg-alt);
    color: var(--color-text-light);
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    cursor: not-allowed;
  }

  .resource-link {
    min-width: 140px;
  }

  .cta-resources {
    background: var(--color-bg-alt);
  }

  .focus-note {
    max-width: 760px;
    margin: 2.5rem auto 0;
    text-align: center;
    background: linear-gradient(180deg, #fff 0%, #fff9f5 100%);
    padding: 2rem;
    border-radius: var(--border-radius);
    border: 1px solid rgba(139, 107, 93, 0.12);
    box-shadow: 0 8px 24px rgba(139, 107, 93, 0.08);
  }

  .focus-note h2 {
    font-size: 1.65rem;
    margin-bottom: 0.85rem;
  }

  .focus-note p {
    color: var(--color-text-light);
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-card {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    background: var(--color-white);
    padding: 3rem;
    border-radius: var(--border-radius);
    box-shadow: 0 4px 20px rgba(139, 107, 93, 0.08);
  }

  .shop-callout {
    max-width: 760px;
    margin: 0 auto 2rem;
    text-align: center;
    background: linear-gradient(180deg, #fff 0%, #fff9f5 100%);
    padding: 2.5rem;
    border-radius: var(--border-radius);
    border: 1px solid rgba(139, 107, 93, 0.12);
    box-shadow: 0 8px 24px rgba(139, 107, 93, 0.08);
  }

  .shop-callout h2 {
    font-size: 1.75rem;
    margin: 0.85rem 0;
  }

  .shop-callout p {
    color: var(--color-text-light);
    max-width: 580px;
    margin: 0 auto 1.5rem;
  }

  .cta-card h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .cta-card p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .resources-hero h1 {
      font-size: 2.25rem;
    }
  }
</style>