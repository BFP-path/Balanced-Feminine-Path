---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'About Dr Oluwaseun Ade-Alade';
---

<BaseLayout title={pageTitle} description="Meet Dr Oluwaseun Ade-Alade, founder of Balanced Feminine Path, and learn how her work supports women through perimenopause, brain fog, mood shifts, and midlife overwhelm.">
  <section class="about-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="page-label">About</span>
        <h1 class="hero-title">Meet Dr Oluwaseun Ade-Alade</h1>
        <p class="lead">
          I created Balanced Feminine Path to give women a steady place for practical support through perimenopause, brain fog, mood shifts, and the confusion that can come with midlife change.
        </p>
        <div class="hero-points">
          <div>
            <span class="point-label">Role</span>
            <p>Founder of Balanced Feminine Path</p>
          </div>
          <div>
            <span class="point-label">Focus</span>
            <p>Perimenopause support, brain fog, mood shifts, rhythm, and practical support tools</p>
          </div>
          <div>
            <span class="point-label">Approach</span>
            <p>Clear guidance, useful structure, and respect for each woman's lived experience</p>
          </div>
        </div>
      </div>

      <div class="portrait-card">
        <img src="/images/dr-oluwaseun-ade-alade.jpg" alt="Dr Oluwaseun Ade-Alade" class="portrait" />
      </div>
    </div>
  </section>

  <section class="section about-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-column">
          <section class="content-card">
            <h2>My story</h2>
            <p>
              Balanced Feminine Path grew from a simple conviction: women need space to understand what their bodies are telling them and make choices from a place of clarity.
            </p>
            <p>
              This platform brings together supportive writing, practical tools, and digital products for women who want more steadiness in the middle of hormonal change, stress, sleep disruption, and everyday demands.
            </p>
            <p>
              My goal is to make this work useful. You should leave with something you can apply,
              track, reflect on, or carry into a better conversation with your healthcare provider.
            </p>
          </section>

          <section class="content-card">
            <h2>What guides my work</h2>
            <div class="values-grid">
              <div class="value-card">
                <span class="value-icon">♡</span>
                <h3>Compassion</h3>
                <p>I want women to feel supported while they figure out what they need.</p>
              </div>
              <div class="value-card">
                <span class="value-icon">☀</span>
                <h3>Clarity</h3>
                <p>I care about simple language, useful tools, and steps that make daily life easier to manage.</p>
              </div>
              <div class="value-card">
                <span class="value-icon">✧</span>
                <h3>Integrity</h3>
                <p>I take women seriously and make room for both reflection and informed care.</p>
              </div>
              <div class="value-card">
                <span class="value-icon">❋</span>
                <h3>Wholeness</h3>
                <p>I look at wellness as something that touches body, mind, rhythm, and lived experience.</p>
              </div>
            </div>
          </section>

          <section class="content-card">
            <h2>What you will find here</h2>
            <ul class="offerings-list">
              <li>
                <strong>Practical resources</strong>
                <span>Guides, trackers, reset plans, and printable tools you can use in real life.</span>
              </li>
              <li>
                <strong>Support for daily rhythm</strong>
                <span>Tools that help with routine, sleep support, symptom awareness, and calmer mornings.</span>
              </li>
              <li>
                <strong>Thoughtful wellness content</strong>
                <span>Writing that helps you understand patterns in perimenopause, brain fog, focus, mood, and energy.</span>
              </li>
              <li>
                <strong>A respectful next step</strong>
                <span>Support that helps you prepare for better decisions and better doctor conversations.</span>
              </li>
            </ul>
          </section>
        </div>

        <aside class="side-column">
          <section class="content-card short-card">
            <h2>About me</h2>
            <dl class="bio-list">
              <div>
                <dt>Name</dt>
                <dd>Dr Oluwaseun Ade-Alade</dd>
              </div>
              <div>
                <dt>Brand</dt>
                <dd>Balanced Feminine Path</dd>
              </div>
              <div>
                <dt>Work</dt>
                <dd>Founder, wellness educator, and creator of digital perimenopause support tools</dd>
              </div>
              <div>
                <dt>Mission</dt>
                <dd>To help women move through midlife with more clarity, steadiness, and self-understanding</dd>
              </div>
            </dl>
          </section>

          <section class="content-card short-card disclaimer-card">
            <h2>Important note</h2>
            <p>
              The content on Balanced Feminine Path is for education and personal reflection. It is not medical advice.
            </p>
            <p>
              Always consult your doctor or another qualified healthcare professional before making decisions about your health,
              symptoms, treatment, supplements, or medication.
            </p>
          </section>
        </aside>
      </div>

      <div class="content-card cta-block">
        <h2>Start where you are</h2>
        <p>
          If you want practical support, start with the free resources or visit the shop for symptom trackers,
          brain fog support tools, reset plans, and guided digital products.
        </p>
        <div class="cta-buttons">
          <a href="/resources" class="btn">Explore Resources</a>
          <a href="/shop" class="btn btn-outline">Visit the Shop</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    padding: 5rem 0 3rem;
  }

  .hero-grid,
  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 3rem;
    align-items: center;
  }

  .hero-copy {
    max-width: 46rem;
  }

  .page-label,
  .point-label {
    display: inline-block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
  }

  .page-label {
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .hero-title {
    white-space: nowrap;
    font-size: clamp(1.85rem, 3vw, 3.1rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.15rem;
  }

  .lead {
    font-size: 1.18rem;
    color: var(--color-text-light);
    max-width: 44rem;
  }

  .hero-points {
    display: grid;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .hero-points p {
    color: var(--color-text-light);
    margin-top: 0.35rem;
  }

  .portrait-card,
  .content-card,
  .value-card {
    background: var(--color-white);
    border-radius: 18px;
    box-shadow: 0 16px 40px rgba(61, 48, 41, 0.08);
  }

  .portrait-card {
    padding: 1rem;
    max-width: 420px;
    justify-self: end;
  }

  .portrait {
    width: 100%;
    display: block;
    border-radius: 14px;
    object-fit: cover;
  }

  .about-content {
    background: var(--color-white);
  }

  .main-column,
  .side-column {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .content-card {
    padding: 2rem;
  }

  .content-card h2 {
    font-size: 1.9rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .content-card p,
  .offerings-list span,
  .bio-list dd {
    color: var(--color-text-light);
  }

  .content-card p + p {
    margin-top: 1rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .value-card {
    padding: 1.5rem;
  }

  .value-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .value-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .offerings-list {
    list-style: none;
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .offerings-list li {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-bg-alt);
  }

  .offerings-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .offerings-list strong {
    display: block;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
  }

  .bio-list {
    display: grid;
    gap: 1rem;
  }

  .bio-list dt {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .bio-list dd {
    margin: 0;
  }

  .disclaimer-card {
    background: linear-gradient(180deg, #fff9f5 0%, #fff 100%);
    border: 1px solid rgba(139, 107, 93, 0.12);
  }

  .cta-block {
    margin-top: 2rem;
    text-align: center;
    background: var(--color-bg-alt);
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  @media (max-width: 1100px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-copy,
    .portrait-card {
      max-width: none;
    }

    .portrait-card {
      justify-self: stretch;
    }

    .hero-title {
      white-space: normal;
    }
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy,
    .portrait-card {
      max-width: none;
    }

    .portrait-card {
      justify-self: stretch;
    }

    .hero-title {
      white-space: normal;
    }
  }
</style>
