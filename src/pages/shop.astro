---
import BaseLayout from '../layouts/BaseLayout.astro';
import { lifestyleMedicinePillars, products } from '../data/products';

const featuredProduct = products.find((product) => product.slug === 'rested-and-radiant-sleep-kit') ?? products[0];
const groupedProducts = lifestyleMedicinePillars.map((pillar) => ({
  ...pillar,
  items: products.filter((product) => product.primaryPillar === pillar.key)
}));
---

<BaseLayout
  title="Shop"
  description="Digital wellness products for perimenopause support, sleep, stress regulation, food planning, symptom tracking, ADHD planning, GLP-1 support, and midlife reset work."
>
  <section class="shop-hero">
    <div class="container hero-grid">
      <div>
        <span class="page-label">Digital Products</span>
        <h1>Shop by the six pillars of lifestyle medicine.</h1>
        <p class="lead">
          The shop now groups every product by nutrition, physical activity, restorative sleep, stress management, social connection, and avoidance of risky substances.
        </p>
        <div class="hero-actions">
          <a href="#pillar-catalog" class="btn">Browse by Pillar</a>
          <a href={`/shop/${featuredProduct.slug}`} class="btn btn-outline">Start with the Sleep Kit</a>
        </div>
      </div>
      <div class="hero-card">
        <span class="hero-card-label">Featured product</span>
        <h2>{featuredProduct.shortTitle}</h2>
        <p>{featuredProduct.promise}</p>
        <div class="hero-card-footer">
          <span class="hero-price">{featuredProduct.price}</span>
          <a href={`/shop/${featuredProduct.slug}`}>View details</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section shop-section" id="pillar-catalog">
    <div class="container">
      <div class="section-intro">
        <span class="page-label">Shop the Collection</span>
        <h2>Choose the support that matches your season.</h2>
        <p>
          Each product now includes a fuller preview workbook and sits inside the lifestyle medicine pillar it supports most.
        </p>
        <p class="shop-disclaimer">
          These tools support education and personal reflection. They do not replace medical care. Always consult your doctor or another qualified healthcare professional about symptoms, treatment, supplements, or medication.
        </p>
      </div>

      <div class="pillar-nav" aria-label="Lifestyle medicine pillars">
        {lifestyleMedicinePillars.map((pillar) => (
          <a href={`#${pillar.key}`} class="pillar-chip">{pillar.name}</a>
        ))}
      </div>

      <div class="pillar-sections">
        {groupedProducts.map((pillar) => (
          <section id={pillar.key} class="pillar-group">
            <div class="pillar-header">
              <div>
                <span class="page-label">Lifestyle medicine pillar</span>
                <h2>{pillar.name}</h2>
              </div>
              <p>{pillar.summary}</p>
            </div>

            <div class="product-grid">
              {pillar.items.map((product) => (
                <article class="product-card" style={`--product-accent: ${product.accent}`}>
                  <div class="product-top">
                    <span class="product-icon">{product.icon}</span>
                    <span class="product-format">{product.format}</span>
                  </div>
                  <div class="product-meta">
                    <span class="primary-pill">{pillar.name}</span>
                    <span class="support-pill-count">+{product.supportPillars.length} support areas</span>
                  </div>
                  <h3>{product.shortTitle}</h3>
                  <p class="product-promise">{product.promise}</p>
                  <p class="product-audience">{product.audience}</p>
                  <ul class="product-list">
                    {product.includes.slice(0, 5).map((item) => <li>{item}</li>)}
                  </ul>
                  <div class="support-pills">
                    {product.supportPillars.map((support) => {
                      const matchingPillar = lifestyleMedicinePillars.find((item) => item.key === support);
                      return <span class="support-pill">Also supports {matchingPillar?.name ?? support}</span>;
                    })}
                  </div>
                  <div class="product-footer">
                    <div>
                      <span class="price-label">Price</span>
                      <span class="price">{product.price}</span>
                    </div>
                    <a href={`/shop/${product.slug}`} class="btn">View product</a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="section comparison-section">
    <div class="container comparison-card">
      <span class="page-label">Need a quick starting point?</span>
      <h2>Pick the product that fits your main need first.</h2>
      <div class="comparison-grid">
        <div>
          <h3>Sleep support</h3>
          <p>Start with the Rested and Radiant Sleep Kit or the Brain Fog and Sleep Guide.</p>
        </div>
        <div>
          <h3>Stress and overwhelm</h3>
          <p>Start with the Perimenopause SOS Kit or the Calm My Hormones Audio Library.</p>
        </div>
        <div>
          <h3>Food, energy, and weight support</h3>
          <p>Start with the Meal Plan for Energy and Mood or the Energy and Weight Rebalance Kit.</p>
        </div>
        <div>
          <h3>Planning and doctor visits</h3>
          <p>Start with the Symptom Tracker and Doctor Checklist or the ADHD Planner for Perimenopause.</p>
        </div>
        <div>
          <h3>One full reset</h3>
          <p>Start with the 4-Week Perimenopause Reset if you want one guided structure.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .shop-hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #fffdfb 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: center;
  }

  .page-label {
    display: inline-block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .shop-hero h1,
  .section-intro h2,
  .pillar-header h2,
  .comparison-card h2 {
    font-size: clamp(2.25rem, 4vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .lead,
  .section-intro p,
  .pillar-header p {
    max-width: 44rem;
    color: var(--color-text-light);
    font-size: 1.08rem;
  }

  .shop-disclaimer {
    margin-top: 1rem;
    font-size: 0.96rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .hero-card,
  .comparison-card,
  .pillar-group {
    background: var(--color-white);
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(61, 48, 41, 0.08);
  }

  .hero-card {
    padding: 2rem;
    border: 1px solid rgba(139, 107, 93, 0.12);
  }

  .hero-card-label,
  .price-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .hero-card h2 {
    font-size: 1.7rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--color-text-light);
  }

  .hero-card-footer,
  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-price,
  .price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-primary);
  }

  .shop-section {
    background: var(--color-white);
  }

  .section-intro {
    margin-bottom: 1.8rem;
  }

  .pillar-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .pillar-chip,
  .support-pill,
  .primary-pill,
  .support-pill-count {
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    font-size: 0.84rem;
  }

  .pillar-chip {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid rgba(139, 107, 93, 0.12);
  }

  .pillar-sections {
    display: grid;
    gap: 2rem;
  }

  .pillar-group {
    padding: 2rem;
  }

  .pillar-header {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: end;
    margin-bottom: 1.75rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: linear-gradient(180deg, #fff 0%, #fdf9f7 100%);
    border: 1px solid rgba(139, 107, 93, 0.12);
    border-top: 4px solid var(--product-accent);
    border-radius: 18px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    box-shadow: 0 12px 30px rgba(61, 48, 41, 0.06);
  }

  .product-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-icon {
    font-size: 2rem;
  }

  .product-format {
    font-size: 0.78rem;
    color: var(--color-text-light);
    text-align: right;
  }

  .product-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }

  .primary-pill {
    background: color-mix(in srgb, var(--product-accent) 14%, white);
    color: var(--color-text);
  }

  .support-pill-count,
  .support-pill {
    background: var(--color-bg-alt);
    color: var(--color-text-light);
  }

  .product-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .product-promise,
  .product-audience,
  .comparison-grid p {
    color: var(--color-text-light);
  }

  .product-audience {
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .product-list {
    list-style: none;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 0.75rem;
  }

  .product-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-light);
  }

  .product-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--product-accent);
  }

  .support-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .product-footer {
    margin-top: auto;
    padding-top: 1.25rem;
  }

  .comparison-section {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
  }

  .comparison-card {
    padding: 2.5rem;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .comparison-grid h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .pillar-header {
      grid-template-columns: 1fr;
    }
  }
</style>
