---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';

const featuredProduct = products[0];
---

<BaseLayout
  title="Shop"
  description="Digital wellness products for perimenopause support, morning routines, symptom tracking, sleep support, and midlife reset work."
>
  <section class="shop-hero">
    <div class="container hero-grid">
      <div>
        <span class="page-label">Digital Products</span>
        <h1>Support for the season you are in right now.</h1>
        <p class="lead">
          Straightforward tools for perimenopause, daily rhythms, sleep support, and midlife reset work.
        </p>
        <div class="hero-actions">
          <a href="#catalog" class="btn">Browse the Collection</a>
          <a href={`/shop/${featuredProduct.slug}`} class="btn btn-outline">Start with the Tracker</a>
        </div>
      </div>
      <div class="hero-card">
        <span class="hero-card-label">Most practical first step</span>
        <h2>{featuredProduct.shortTitle}</h2>
        <p>{featuredProduct.promise}</p>
        <div class="hero-card-footer">
          <span class="hero-price">{featuredProduct.price}</span>
          <a href={`/shop/${featuredProduct.slug}`}>View details</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section shop-section" id="catalog">
    <div class="container">
      <div class="section-intro">
        <span class="page-label">Shop the Collection</span>
        <h2>Choose the tool that matches what your body needs.</h2>
        <p>
          Every product includes guided pages you can print, use on a tablet, or revisit when symptoms change.
        </p>
        <p class="shop-disclaimer">
          These tools support education and personal reflection. They do not replace medical care. Always consult your doctor or another qualified healthcare professional about symptoms, treatment, supplements, or medication.
        </p>
      </div>

      <div class="product-grid">
        {products.map((product) => (
          <article class="product-card" style={`--product-accent: ${product.accent}`}>
            <div class="product-top">
              <span class="product-icon">{product.icon}</span>
              <span class="product-format">{product.format}</span>
            </div>
            <h3>{product.shortTitle}</h3>
            <p class="product-promise">{product.promise}</p>
            <p class="product-audience">{product.audience}</p>
            <ul class="product-list">
              {product.includes.slice(0, 4).map((item) => <li>{item}</li>)}
            </ul>
            <div class="product-footer">
              <div>
                <span class="price-label">Price</span>
                <span class="price">{product.price}</span>
              </div>
              <a href={`/shop/${product.slug}`} class="btn">View product</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section comparison-section">
    <div class="container comparison-card">
      <span class="page-label">Need a simple starting point?</span>
      <h2>Start with the product that matches your main symptom.</h2>
      <div class="comparison-grid">
        <div>
          <h3>Tracking symptoms</h3>
          <p>Choose the Symptom Tracker + Doctor Prep Kit.</p>
        </div>
        <div>
          <h3>Calmer mornings</h3>
          <p>Choose the 14-Day Morning Ritual Reset.</p>
        </div>
        <div>
          <h3>Sleep and brain fog</h3>
          <p>Choose the Sleep + Brain Fog Relief Kit.</p>
        </div>
        <div>
          <h3>Food and energy</h3>
          <p>Choose the Food + Energy Reset.</p>
        </div>
        <div>
          <h3>Complete month-long reset</h3>
          <p>Choose the 4-Week Midlife Reset.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .shop-hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #fffdfb 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: center;
  }

  .page-label {
    display: inline-block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .shop-hero h1,
  .section-intro h2,
  .comparison-card h2 {
    font-size: clamp(2.25rem, 4vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .lead,
  .section-intro p {
    max-width: 42rem;
    color: var(--color-text-light);
    font-size: 1.1rem;
  }

  .shop-disclaimer {
    margin-top: 1rem;
    font-size: 0.96rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .hero-card,
  .comparison-card {
    background: var(--color-white);
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(61, 48, 41, 0.08);
  }

  .hero-card {
    padding: 2rem;
    border: 1px solid rgba(139, 107, 93, 0.12);
  }

  .hero-card-label,
  .price-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .hero-card h2 {
    font-size: 1.7rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--color-text-light);
  }

  .hero-card-footer,
  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-price,
  .price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-primary);
  }

  .shop-section {
    background: var(--color-white);
  }

  .section-intro {
    margin-bottom: 2rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: linear-gradient(180deg, #fff 0%, #fdf9f7 100%);
    border: 1px solid rgba(139, 107, 93, 0.12);
    border-top: 4px solid var(--product-accent);
    border-radius: 18px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    box-shadow: 0 12px 30px rgba(61, 48, 41, 0.06);
  }

  .product-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-icon {
    font-size: 2rem;
  }

  .product-format {
    font-size: 0.78rem;
    color: var(--color-text-light);
    text-align: right;
  }

  .product-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .product-promise,
  .product-audience,
  .comparison-grid p {
    color: var(--color-text-light);
  }

  .product-audience {
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .product-list {
    list-style: none;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 0.75rem;
  }

  .product-list li {
    position: relative;
    padding-left: 1rem;
    color: var(--color-text-light);
  }

  .product-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--product-accent);
  }

  .product-footer {
    margin-top: auto;
    padding-top: 1.25rem;
  }

  .comparison-section {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
  }

  .comparison-card {
    padding: 2.5rem;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .comparison-grid h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
